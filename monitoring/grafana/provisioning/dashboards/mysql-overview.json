    {
      "title": "InnoDB Buffer Pool",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "mysql_global_status_innodb_buffer_pool_pages_total * 16384",
