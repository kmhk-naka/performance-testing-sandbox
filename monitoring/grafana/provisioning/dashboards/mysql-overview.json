          "legendFormat": "Used (Data)"
        },
        {
          "expr": "mysql_global_status_innodb_buffer_pool_pages_free * 16384",
          "legendFormat": "Free"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      }
    },
